{
  "name": "rsbuild-react-base",
  "version": "0.1.0",
  "author": "agustinusnathaniel",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.x"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "neverBuiltDependencies": []
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "build-and-analyze": "cross-env RSDOCTOR=true pnpm build",
    "preview": "rsbuild preview",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "biome:ci": "biome ci",
    "type:check": "tsc --noEmit",
    "test": "rstest",
    "turbo": "pnpm dlx turbo@2.7.2",
    "check:turbo": "pnpm turbo ultracite:check type:check test",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 standard-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "husky",
    "knip": "knip"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@theme-toggles/react": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/cz-commitlint": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@rsbuild/core": "1.7.3",
    "@rsbuild/plugin-assets-retry": "1.5.2",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-image-compress": "^1.3.2",
    "@rsbuild/plugin-react": "1.4.6",
    "@rsbuild/plugin-svgr": "1.3.1",
    "@rsbuild/plugin-type-check": "1.3.4",
    "@rsdoctor/rspack-plugin": "^1.5.3",
    "@rstest/core": "^0.9.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.7",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.6.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "husky": "9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  }
}
